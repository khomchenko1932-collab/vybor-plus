# Скопируйте в .env и вставьте серверный ключ. Не добавляйте .env в Git.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
PORT=8787
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
DEMO_FALLBACK=true
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
REQUEST_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=0
MAX_BODY_BYTES=100000

# Для физического телефона укажите IP компьютера в локальной сети:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8787

# Supabase authentication and cloud history sync:
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
